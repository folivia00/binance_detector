# =============================================================================
# Binance Detector — Environment Variables
# =============================================================================
# Add to ~/.bashrc on VPS (or export in current session for local testing).
# NEVER commit a filled .env file — it is in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Polymarket — Live Trading
# Step 1: set private key + address, run setup_pm_api_key.py to get API creds
# Step 2: set the three PM_API_* vars below
# ---------------------------------------------------------------------------
PM_PRIVATE_KEY=0x<your_polygon_wallet_private_key>
PM_FUNDER_ADDRESS=0x<your_wallet_address>
PM_SIGNATURE_TYPE=2

# Derive once with: python scripts/setup_pm_api_key.py
PM_API_KEY=<from_setup_script>
PM_API_SECRET=<from_setup_script>
PM_API_PASSPHRASE=<from_setup_script>

# ---------------------------------------------------------------------------
# Polygon RPC — for run_redeem.py (optional, default: https://polygon-rpc.com)
# Use a private RPC (Alchemy/Infura) for better reliability on VPS
# ---------------------------------------------------------------------------
POLYGON_RPC_URL=https://polygon-rpc.com

# ---------------------------------------------------------------------------
# Binance — NOT required (all endpoints are public, no auth needed)
# ---------------------------------------------------------------------------
