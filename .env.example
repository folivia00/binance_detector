# =============================================================================
# Binance Detector — Environment Variables
# =============================================================================
# Copy this file to .env on VPS, fill in the values, then:
#   source .env  (or add to ~/.bashrc for persistence)
#
# NEVER commit a filled .env file to git — it is in .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Polymarket — Live Trading (signature_type=2, no API keys needed)
# ---------------------------------------------------------------------------
PM_PRIVATE_KEY=0x<your_polygon_wallet_private_key>
PM_FUNDER_ADDRESS=0x<your_wallet_address>
PM_SIGNATURE_TYPE=2

# ---------------------------------------------------------------------------
# Binance — Optional (public endpoints work without auth for read-only data)
# ---------------------------------------------------------------------------
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---------------------------------------------------------------------------
# Paths (optional overrides, defaults are relative to project root)
# ---------------------------------------------------------------------------
# MODEL_PATH=data/models/latest.pkl
# LOG_LEVEL=INFO
